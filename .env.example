# Public Supabase credentials for the online leaderboard (safe to ship — security is
# enforced server-side via RLS + the submit_score RPC). Copy to `.env` and fill in,
# and set the same two vars in Vercel's project env. Leave unset to disable leaderboards.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
