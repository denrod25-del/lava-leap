# E2E runs against the shipping DEFAULT (leaderboards dormant), independent of any
# developer's local .env. Vite's mode-specific .env.test overrides .env, so these
# blanks force leaderboardEnabled=false during `vite --mode test`. Safe to commit
# (no secrets — just empty public vars).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
