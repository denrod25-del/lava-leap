# Supabase project URL and keys.
# Find these in your Supabase dashboard: Project Settings -> API

# Public (safe for the browser) — used for the estimator form + photo uploads
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only service role key — used by the admin dashboard to read every lead.
# NEVER expose this in client code or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Simple shared password that protects the /admin dashboard.
ADMIN_PASSWORD=change-me

# Name of the public Storage bucket that holds uploaded heater photos.
NEXT_PUBLIC_SUPABASE_PHOTO_BUCKET=lead-photos
